<!DOCTYPE html>
<html lang="de">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover, maximum-scale=1">
  <title>Lumi English Adventure</title>
  <meta name="theme-color" content="#f4f7fb">
  <meta name="apple-mobile-web-app-capable" content="yes">
  <meta name="apple-mobile-web-app-status-bar-style" content="default">
  <meta name="apple-mobile-web-app-title" content="Lumi English">
  <link rel="manifest" href="manifest.webmanifest">
  <link rel="apple-touch-icon" href="icons/icon-180.png">
  <link rel="icon" type="image/png" sizes="192x192" href="icons/icon-192.png">
  <link rel="icon" type="image/png" sizes="512x512" href="icons/icon-512.png">
  <style>
    :root {
      --bg:#f4f7fb;
      --card:#ffffff;
      --ink:#203047;
      --muted:#6a778a;
      --line:#dde7f2;
      --primary:#3b6eea;
      --primary2:#6f91f3;
      --green:#2a9d68;
      --orange:#f0a029;
      --red:#cf4d4d;
      --soft:#eef3ff;
      --shadow:0 12px 34px rgba(32,48,71,.10);
      --radius:20px;
    }
    * { box-sizing:border-box; }
    html { -webkit-text-size-adjust:100%; text-size-adjust:100%; background:var(--bg); }
    body {
      margin:0;
      font-family:-apple-system,BlinkMacSystemFont,"SF Pro Text","SF Pro Display",Inter,system-ui,Segoe UI,Roboto,Arial,sans-serif;
      color:var(--ink);
      background:
        radial-gradient(circle at 15% 0%, rgba(111,145,243,.22), transparent 34%),
        radial-gradient(circle at 95% 12%, rgba(240,160,41,.16), transparent 28%),
        var(--bg);
      min-height:100vh; min-height:100dvh;
      padding:env(safe-area-inset-top) env(safe-area-inset-right) env(safe-area-inset-bottom) env(safe-area-inset-left);
      -webkit-tap-highlight-color:transparent;
    }
    button,input,textarea { font:inherit; font-size:16px; }
    button,input,textarea { -webkit-appearance:none; appearance:none; }
    button { touch-action:manipulation; }
    :focus-visible { outline:3px solid rgba(59,110,234,.35); outline-offset:2px; }
    .app { max-width:1220px; margin:0 auto; padding:clamp(12px,2vw,22px); }
    header {
      display:flex; justify-content:space-between; align-items:center; gap:14px;
      margin:4px 0 16px;
    }
    .brand h1 { margin:0; font-size:clamp(25px,4vw,40px); letter-spacing:-.02em; }
    .brand p { margin:5px 0 0; color:var(--muted); }
    .top-stats { display:flex; gap:8px; flex-wrap:wrap; justify-content:flex-end; }
    .chip {
      background:rgba(255,255,255,.86);
      border:1px solid var(--line);
      padding:8px 12px;
      border-radius:999px;
      font-weight:800;
      box-shadow:0 4px 14px rgba(32,48,71,.05);
      white-space:nowrap;
    }
    .layout { display:grid; grid-template-columns:310px minmax(0,1fr); gap:18px; align-items:start; }
    .card {
      background:rgba(255,255,255,.92);
      backdrop-filter:saturate(140%) blur(8px);
      border:1px solid var(--line);
      border-radius:var(--radius);
      box-shadow:var(--shadow);
    }
    aside { padding:16px; position:sticky; top:12px; }
    main { padding:22px; min-height:700px; }
    .stat { margin:0 0 15px; }
    .stat-row { display:flex; justify-content:space-between; gap:10px; margin:0 0 7px; font-size:14px; color:var(--muted); }
    .stat-row strong { color:var(--ink); }
    .bar { height:12px; background:#e8eef7; border-radius:999px; overflow:hidden; }
    .bar span { display:block; height:100%; width:0%; border-radius:999px; background:linear-gradient(90deg,var(--primary),var(--primary2)); transition:width .35s ease; }
    nav { display:grid; gap:6px; }
    nav button {
      border:0; background:transparent; min-height:48px; padding:12px;
      border-radius:13px; text-align:left; color:var(--ink); cursor:pointer;
    }
    nav button.active, nav button:hover { background:var(--soft); color:#244fb8; font-weight:900; }
    .small { color:var(--muted); font-size:13px; }
    .notice {
      background:#fff8e7; border:1px solid #f2d48b; color:#75530f;
      border-radius:14px; padding:13px 14px; margin:0 0 16px;
    }
    .hero {
      display:flex; align-items:center; justify-content:space-between; gap:18px;
      padding:24px; border-radius:18px; border:1px solid #d8e3ff;
      background:linear-gradient(135deg,#edf3ff,#fbfdff);
      margin-bottom:18px;
    }
    .hero h2 { margin:0 0 7px; font-size:clamp(24px,3vw,34px); }
    .hero p { margin:0; color:var(--muted); max-width:760px; line-height:1.45; }
    .btn {
      border:0; border-radius:13px; min-height:48px; padding:12px 16px;
      font-weight:900; cursor:pointer; background:var(--primary); color:white;
      white-space:nowrap;
    }
    .btn.secondary { background:white; color:var(--ink); border:1px solid var(--line); }
    .btn.ghost { background:var(--soft); color:#244fb8; }
    .btn.warn { background:#fff2f2; color:#9b3131; border:1px solid #f1b4b4; }
    .btn:disabled { opacity:.5; cursor:not-allowed; }
    .grid2 { display:grid; grid-template-columns:repeat(2,minmax(0,1fr)); gap:14px; }
    .grid3 { display:grid; grid-template-columns:repeat(3,minmax(0,1fr)); gap:14px; }
    .mini { padding:16px; border:1px solid var(--line); border-radius:16px; background:#fff; }
    .mini strong { display:block; font-size:26px; margin-bottom:2px; }
    .grade-title { margin:24px 0 10px; display:flex; align-items:center; justify-content:space-between; gap:12px; }
    .unit-list { display:grid; gap:12px; }
    .unit {
      display:grid; grid-template-columns:56px 1fr auto; gap:14px; align-items:center;
      padding:16px; border:1px solid var(--line); border-radius:17px; background:#fff;
    }
    .unit.done { border-color:#9bdbbd; background:#f5fff9; }
    .unit.locked { opacity:.58; }
    .icon {
      width:52px; height:52px; border-radius:16px; display:grid; place-items:center;
      background:var(--soft); font-size:25px; font-weight:900;
    }
    .unit-title { font-weight:950; font-size:18px; }
    .unit-meta { color:var(--muted); margin-top:4px; font-size:14px; line-height:1.35; }
    .tagline { display:flex; flex-wrap:wrap; gap:6px; margin-top:8px; }
    .tag { padding:5px 8px; border-radius:999px; background:#f1f5fb; color:#536176; font-size:12px; font-weight:700; }
    .missions { display:grid; gap:12px; }
    .mission {
      display:grid; grid-template-columns:46px 1fr auto; gap:13px; align-items:center;
      padding:15px; border:1px solid var(--line); border-radius:16px; background:#fff;
    }
    .mission.done { border-color:#9bdbbd; background:#f6fff9; }
    .mission.locked { opacity:.55; }
    .mission .icon { width:44px; height:44px; border-radius:14px; font-size:20px; }
    .skills { display:flex; gap:5px; flex-wrap:wrap; margin-top:8px; }
    .skill { font-size:11px; font-weight:900; color:#244fb8; background:#edf3ff; padding:4px 7px; border-radius:999px; }
    .lesson-head {
      display:flex; justify-content:space-between; gap:18px; align-items:flex-start; margin-bottom:18px;
    }
    .lesson-head h2 { margin:0 0 4px; }
    .pill { padding:7px 10px; border-radius:999px; background:#edf3ff; color:#244fb8; font-weight:900; font-size:13px; white-space:nowrap; }
    .question { padding:20px; border:1px solid var(--line); border-radius:18px; background:#fff; margin-top:14px; }
    .question h3 { margin:0 0 12px; font-size:21px; }
    .question p { line-height:1.5; }
    .answers { display:grid; gap:10px; margin-top:14px; }
    .answer {
      min-height:50px; padding:14px; border:1px solid var(--line); border-radius:13px;
      background:#fff; cursor:pointer; text-align:left;
    }
    .answer:hover, .answer.selected { border-color:var(--primary); background:#eef3ff; }
    .answer.correct { border-color:var(--green); background:#effcf5; }
    .answer.wrong { border-color:var(--red); background:#fff1f1; }
    input.text, textarea.text {
      width:100%; min-height:50px; padding:13px; border:1px solid var(--line); border-radius:13px;
      background:white; color:var(--ink);
    }
    textarea.text { min-height:110px; resize:vertical; }
    .feedback { display:none; margin-top:14px; padding:13px; border-radius:13px; line-height:1.45; }
    .feedback.show { display:block; }
    .feedback.ok { background:#effcf5; color:#166944; }
    .feedback.no { background:#fff4e5; color:#8b570d; }
    .actions { display:flex; justify-content:flex-end; gap:10px; flex-wrap:wrap; margin-top:16px; }
    .result { text-align:center; padding:36px 10px; }
    .result .big { font-size:66px; }
    .result h2 { margin:8px 0; font-size:30px; }
    table { width:100%; border-collapse:collapse; background:white; border-radius:16px; overflow:hidden; }
    th,td { padding:12px; border-bottom:1px solid var(--line); text-align:left; vertical-align:top; }
    th { color:#526176; font-size:13px; }
    .progress-row { display:flex; align-items:center; gap:8px; }
    .progress-row .bar { flex:1; height:9px; }
    .footer { color:var(--muted); font-size:12px; text-align:center; padding:16px; }
    @media(max-width:920px) {
      .layout { grid-template-columns:1fr; }
      aside { position:static; }
      nav { grid-template-columns:repeat(2,minmax(0,1fr)); }
      nav button { text-align:center; }
      main { min-height:auto; padding:16px; }
      .hero { flex-direction:column; align-items:flex-start; }
      .grid2,.grid3 { grid-template-columns:1fr; }
      .unit,.mission { grid-template-columns:48px 1fr; }
      .unit .btn,.mission .btn { grid-column:1/-1; width:100%; }
    }
    @media(min-width:768px) and (max-width:1180px) {
      .app { max-width:1040px; }
    }
    @media(orientation:landscape) and (max-height:700px) {
      header { margin-bottom:10px; }
      aside,main { padding:14px; }
    }
    @media(prefers-reduced-motion:reduce) {
      * { scroll-behavior:auto!important; transition:none!important; animation:none!important; }
    }
    @supports(-webkit-touch-callout:none) {
      input,textarea { font-size:16px!important; }
      .card { box-shadow:0 8px 26px rgba(32,48,71,.08); }
    }
  </style>
</head>
<body>
  <div class="app">
    <header>
      <div class="brand">
        <h1>🌟 Lumi English Adventure</h1>
        <p>Leuchtturmwagen · Klasse 5 & 6 · PWA-Version 0.4</p>
      </div>
      <div class="top-stats">
        <span class="chip" id="sparkChip">✨ 0 Lichtfunken</span>
        <span class="chip" id="crystalChip">💎 0 Lichtkristalle</span>
      </div>
    </header>

    <div class="layout">
      <aside class="card">
        <div class="stat">
          <div class="stat-row"><strong>Gesamtfortschritt</strong><span id="overallText">0 %</span></div>
          <div class="bar"><span id="overallBar"></span></div>
        </div>
        <div class="stat">
          <div class="stat-row"><span>🔥 Lernserie</span><strong id="streakText">0 Tage</strong></div>
          <div class="stat-row"><span>✅ Missionen</span><strong id="missionDoneText">0</strong></div>
        </div>
        <nav>
          <button class="active" data-view="dashboard">🏠 Übersicht</button>
          <button data-view="path">🗺️ Lernpfad</button>
          <button data-view="today">⏱️ Heute lernen</button>
          <button data-view="review">🔁 Wiederholen</button>
          <button data-view="parents">📊 Elternbereich</button>
          <button data-view="settings">⚙️ Technik</button>
        </nav>
      </aside>

      <section style="min-width:0">
        <div id="installHint" class="notice" style="display:none">
          <strong>Auf dem iPad installieren:</strong>
          Diese GitHub-Pages-Adresse direkt in Safari öffnen, dann <strong>Teilen</strong> und
          <strong>„Zum Home-Bildschirm“</strong> wählen.
          <button class="btn secondary" style="min-height:38px;margin-left:8px;padding:7px 10px" onclick="dismissInstallHint()">Verstanden</button>
        </div>
        <main class="card" id="main"></main>
      </section>
    </div>
    <div class="footer">Alle Übungen, Texte und Beispiele sind eigenständig für diese App formuliert. Der Lernpfad orientiert sich an den angegebenen Unit-Zielen.</div>
  </div>

<script>
window.APP_CONTENT = {"schemaVersion":"0.2.0","appName":"Lumi English Adventure","contentScope":{"grades":[5,6],"futureGradesPrepared":[7,8,9,10],"dailyLearningTimeMinutes":20,"passThresholdPercent":80,"contentRule":"The app follows the textbook unit order and learning goals, but all exercises, texts, stories and examples are original app content."},"skillCodes":{"VOC":"Vocabulary","GRA":"Grammar","REA":"Reading","LIS":"Listening","SPE":"Speaking","WRI":"Writing","MED":"Mediation","VIE":"Viewing","STU":"Study skills","INT":"Intercultural competence"},"taskTypes":["multiple-choice","text-input","sentence-builder","matching","sorting","gap-fill","error-correction","mini-writing","reading-check","listening-check","speaking-prompt","mediation-choice","viewing-scene","unit-test"],"rewardSystem":{"basicReward":"Lichtfunke","majorReward":"Lichtkristall","starsPerMission":1,"starsPerUnitTest":3,"badges":["First Light","Word Explorer","Grammar Builder","Reading Hero","Speaking Star","Writing Wizard","Unit Champion"]},"missionTemplate":[{"step":1,"type":"mini-story","durationMinutes":1},{"step":2,"type":"learning-goal","durationMinutes":1},{"step":3,"type":"vocabulary-check","durationMinutes":4},{"step":4,"type":"main-practice","durationMinutes":9},{"step":5,"type":"mini-challenge","durationMinutes":3},{"step":6,"type":"feedback-and-reward","durationMinutes":2}],"grades":[{"grade":5,"gradeTitle":"Klasse 5","profileMode":"beginner","mainGoal":"Einen sicheren Einstieg in Englisch schaffen und Grundlagen spielerisch aufbauen.","tone":"spielerisch, langsam, erklärend, viele Erfolgserlebnisse","world":{"id":"g5-school-harbour","title":"School Harbour","storyArc":"Das Kind entdeckt Lighthouse Island zum ersten Mal und lernt die wichtigsten englischen Grundlagen, um sich auf der Insel zurechtzufinden."},"units":[{"id":"g5-u0","order":0,"bookUnit":"Nice to meet you!","appTitle":"First Steps on Lighthouse Island","status":"core","focus":["sich begrüßen","sich vorstellen","Farben","Sportarten","Hobbys","Tiere","Lieblingsgegenstände","erste einfache Sätze"],"grammarFocus":["I am","I like","I don't like","My favourite ... is ..."],"vocabFields":["greetings","colours","sports","hobbies","animals","things"],"missions":[{"id":"g5-u0-m1","section":"Meet Cyril","appMissionTitle":"Hello, Lighthouse Island","skills":["SPE","LIS","VOC"],"learningGoals":["Ich kann jemanden begrüßen.","Ich kann meinen Namen sagen.","Ich kann sagen, was ich auf einem Bild sehe."],"targetPhrases":["Hello.","Hi, I’m ...","My name is ...","I can see ..."],"taskTypes":["multiple-choice","matching","speaking-prompt"]},{"id":"g5-u0-m2","section":"My favourite colours","appMissionTitle":"Colour Code","skills":["VOC","SPE"],"learningGoals":["Ich kann Farben benennen.","Ich kann meine Lieblingsfarbe sagen."],"targetPhrases":["My favourite colour is ...","It is blue.","I like red."],"taskTypes":["matching","multiple-choice","text-input"]},{"id":"g5-u0-m3","section":"My favourite sports and hobbies","appMissionTitle":"Hobby Harbour","skills":["VOC","SPE","WRI"],"learningGoals":["Ich kann sagen, welche Hobbys ich mag.","Ich kann sagen, welche Hobbys ich nicht mag."],"targetPhrases":["I like football.","I don’t like watching TV.","My hobby is ..."],"taskTypes":["multiple-choice","sentence-builder","mini-writing"]},{"id":"g5-u0-m4","section":"My favourite animals","appMissionTitle":"Animal Friends","skills":["VOC","SPE"],"learningGoals":["Ich kann Lieblingstiere benennen.","Ich kann einen kurzen Satz über ein Tier sagen."],"targetPhrases":["My favourite animal is ...","It is big.","It is funny."],"taskTypes":["matching","text-input","speaking-prompt"]},{"id":"g5-u0-m5","section":"My favourite thing","appMissionTitle":"My Special Thing","skills":["VOC","WRI"],"learningGoals":["Ich kann meinen Lieblingsgegenstand beschreiben.","Ich kann einfache Adjektive benutzen."],"targetPhrases":["My favourite thing is ...","It’s new.","It’s big."],"taskTypes":["gap-fill","sentence-builder","mini-writing"]},{"id":"g5-u0-m6","section":"Story","appMissionTitle":"The Last Holiday Spark","skills":["REA","VOC"],"learningGoals":["Ich kann eine einfache Geschichte verstehen.","Ich kann einzelne Informationen aus einer Geschichte erkennen."],"taskTypes":["reading-check","multiple-choice","sorting"]}]},{"id":"g5-u1","order":1,"bookUnit":"Unit 1 · Welcome to our school","appTitle":"Welcome to School Harbour","status":"core","focus":["Schule","Klasse","sich und andere vorstellen","Stundenplan","Schulfächer","Schulräume","Schulalltag"],"grammarFocus":["to be positive","to be negative","I’m / he’s / they’re","I’m not / she isn’t / we aren’t"],"vocabFields":["school","classroom","lessons","days of the week","teachers","school things"],"missions":[{"id":"g5-u1-m1","section":"Lead-in","appMissionTitle":"The First Morning","skills":["LIS","SPE","VOC"],"learningGoals":["Ich kann jemanden in der Schule begrüßen.","Ich kann mich verabschieden."],"targetPhrases":["Hello, I’m ...","How are you?","Goodbye.","See you later."],"taskTypes":["listening-check","multiple-choice","speaking-prompt"]},{"id":"g5-u1-m2","section":"Theme 1","appMissionTitle":"Me and My Class","skills":["SPE","WRI","STU"],"learningGoals":["Ich kann mich vorstellen.","Ich kann andere Personen vorstellen.","Ich kann kurze Notizen über mich machen."],"targetPhrases":["I’m ...","I have ...","She’s ...","They’re ..."],"taskTypes":["sentence-builder","gap-fill","mini-writing"]},{"id":"g5-u1-m3","section":"Theme 2","appMissionTitle":"My First Timetable","skills":["LIS","SPE","INT"],"learningGoals":["Ich kann über einen Stundenplan sprechen.","Ich kenne wichtige Schulfächer und Wochentage."],"targetPhrases":["What’s the next lesson?","On Monday I have English.","My favourite lesson is ..."],"taskTypes":["matching","sorting","speaking-prompt"]},{"id":"g5-u1-m4","section":"Focus on Language","appMissionTitle":"The To Be Machine","skills":["GRA","WRI"],"learningGoals":["Ich kann Formen von to be benutzen.","Ich kann einfache Verneinungen bilden."],"targetPhrases":["I am","you are","he is","she isn’t","we aren’t"],"taskTypes":["gap-fill","error-correction","sentence-builder"],"errorCategories":["to-be-forms","to-be-negative"]},{"id":"g5-u1-m5","section":"Story / Reading","appMissionTitle":"The Uniform Question","skills":["REA","STU"],"learningGoals":["Ich kann eine Schulgeschichte verstehen.","Ich kann Wörter sinnvoll gruppieren."],"taskTypes":["reading-check","sorting","multiple-choice"]},{"id":"g5-u1-m6","section":"Skills","appMissionTitle":"Talking to Friends at School","skills":["SPE","WRI","STU"],"learningGoals":["Ich kann einfache Fragen zum Schulalltag stellen.","Ich kann kurze Antworten notieren."],"targetPhrases":["Who’s your favourite teacher?","What’s your favourite lesson?","The next lesson is ..."],"taskTypes":["speaking-prompt","mini-writing","matching"]},{"id":"g5-u1-m7","section":"Stop Check Go","appMissionTitle":"School Harbour Check","skills":["VOC","GRA","REA","LIS","SPE","WRI"],"learningGoals":["Ich wiederhole die wichtigsten Inhalte der Unit.","Ich erkenne, was ich schon sicher kann."],"taskTypes":["unit-test"]}]},{"id":"g5-u2","order":2,"bookUnit":"Unit 2 · At home with Ellie","appTitle":"Ellie’s Home Bay","status":"core","focus":["Zuhause","Wohnungen und Häuser","Familie","Zimmer","Besitz","Adressen","Telefonnummern","Buchstabieren"],"grammarFocus":["there is / there are","questions and short answers with be","possessive ideas","classroom English"],"vocabFields":["home","rooms","family","furniture","addresses","alphabet","phone numbers"],"missions":[{"id":"g5-u2-m1","section":"Lead-in","appMissionTitle":"Homes on the Island","skills":["SPE","LIS","VOC"],"learningGoals":["Ich kann Häuser und Wohnungen einfach beschreiben."],"targetPhrases":["My flat is big.","It has ...","There is ..."],"taskTypes":["matching","multiple-choice","speaking-prompt"]},{"id":"g5-u2-m2","section":"Theme 1","appMissionTitle":"Ellie’s Family","skills":["WRI","SPE","STU"],"learningGoals":["Ich kann über Familie sprechen.","Ich kann Wörter zum Thema Familie gruppieren."],"taskTypes":["sorting","sentence-builder","mini-writing"]},{"id":"g5-u2-m3","section":"Theme 2","appMissionTitle":"My Room","skills":["SPE","VOC","WRI"],"learningGoals":["Ich kann ein Zimmer beschreiben.","Ich kann sagen, was es in einem Zimmer gibt."],"targetPhrases":["There’s a desk.","There are two chairs.","My bed is next to the window."],"taskTypes":["gap-fill","sentence-builder","mini-writing"]},{"id":"g5-u2-m4","section":"Focus on Language","appMissionTitle":"Question Gate","skills":["GRA","SPE"],"learningGoals":["Ich kann Fragen mit be stellen.","Ich kann kurze Antworten geben."],"targetPhrases":["Are your friends fun?","Yes, they are.","No, they aren’t."],"taskTypes":["multiple-choice","gap-fill","sentence-builder"],"errorCategories":["to-be-questions","short-answers"]},{"id":"g5-u2-m5","section":"Story / Writing","appMissionTitle":"Two Homes Diary","skills":["REA","WRI"],"learningGoals":["Ich kann einen einfachen Tagebucheintrag verstehen.","Ich kann einen kurzen Tagebucheintrag schreiben."],"taskTypes":["reading-check","mini-writing"]},{"id":"g5-u2-m6","section":"Skills","appMissionTitle":"Address and Alphabet Mission","skills":["LIS","SPE","STU"],"learningGoals":["Ich kann eine Adresse verstehen.","Ich kann Wörter buchstabieren.","Ich kann nachfragen."],"targetPhrases":["What’s your address?","Can you spell that, please?","Can you say that again, please?"],"taskTypes":["listening-check","speaking-prompt","text-input"]},{"id":"g5-u2-m7","section":"Stop Check Go","appMissionTitle":"Home Bay Check","skills":["VOC","GRA","REA","LIS","SPE","WRI"],"taskTypes":["unit-test"]}]},{"id":"g5-u3","order":3,"bookUnit":"Unit 3 · My Plymouth","appTitle":"Plymouth Town Trail","status":"core","focus":["Wohnort","Stadt","Wochenende","Kleidung","Geburtstage","Datum","Preise","Einkaufen"],"grammarFocus":["simple present with frequency adverbs","always / sometimes / never","third person singular -s