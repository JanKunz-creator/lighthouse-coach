 Quest","skills":["LIS","SPE","VIE","INT"],"learningGoals":["Ich kann nach dem Weg fragen.","Ich kann einen einfachen Weg beschreiben.","Ich kann eine englische Nachbarschaft kennenlernen."],"targetPhrases":["Turn right at the traffic lights.","Go straight on.","Go past the shop."],"taskTypes":["listening-check","speaking-prompt","viewing-scene"]},{"id":"g6-u2-m7","section":"Stop Check Go","appMissionTitle":"Neighbours Check","skills":["VOC","GRA","REA","LIS","SPE","WRI"],"taskTypes":["unit-test"]}]},{"id":"g6-u3","order":3,"bookUnit":"Unit 3 · Teen talk","appTitle":"Teen Talk Coast","status":"core","focus":["Wochenende","Umfragen","Taschengeld","Jobs","Hausarbeit","Verabredungen","Zukunftspläne","Kurzvortrag","Fernsehprogramme"],"grammarFocus":["going to-future","comparison of adjectives","comparative","superlative"],"vocabFields":["weekend activities","pocket money","jobs","chores","arrangements","TV programmes","talk phrases"],"missions":[{"id":"g6-u3-m1","section":"Lead-in","bookSectionTitle":"What makes a perfect weekend?","appMissionTitle":"Perfect Weekend","skills":["LIS","SPE","WRI"],"learningGoals":["Ich kann sagen, was ich am Wochenende gerne tue.","Ich kann einfache Umfrageergebnisse wiedergeben."],"targetPhrases":["I like doing sport because it’s fun.","One student did sport."],"taskTypes":["multiple-choice","mini-writing","speaking-prompt"]},{"id":"g6-u3-m2","section":"Theme 1","bookSectionTitle":"Money questions","appMissionTitle":"Money Mission","skills":["LIS","SPE","REA"],"learningGoals":["Ich kann über Taschengeld sprechen.","Ich kann sagen, welche Arbeiten ich im Haus mache."],"targetPhrases":["I don’t get any pocket money.","I do lots of chores."],"taskTypes":["reading-check","gap-fill","speaking-prompt"]},{"id":"g6-u3-m3","section":"Theme 2","bookSectionTitle":"Making arrangements","appMissionTitle":"Plan the Future","skills":["REA","SPE","STU","LIS"],"learningGoals":["Ich kann Verabredungen machen.","Ich kann Pläne mit going to ausdrücken."],"t